{
  "manifest_version": 3,
  "name": "Domain Environment Switcher",
  "version": "1.0.0",
  "description": "Quickly switch between development, production, and local environments",
  "permissions": ["storage", "tabs", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/inactive16.png",
      "48": "icons/inactive48.png",
      "128": "icons/inactive128.png"
    }
  },
  "icons": {
    "16": "icons/inactive16.png",
    "48": "icons/inactive48.png",
    "128": "icons/inactive128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}